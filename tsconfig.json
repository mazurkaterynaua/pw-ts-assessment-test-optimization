{
    "compilerOptions": {
        "target": "es2021",
        "module": "commonjs",
        "strict": true,
        "noImplicitAny": true,
        "strictNullChecks": true,
        "moduleResolution": "node",
        "resolveJsonModule": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "types": ["node"],
        "sourceMap": true,
        "outDir": "./dist",
        "declaration": true
    },
    "include": ["./tests", "tests/.spec.ts"],
    "exclude": ["node_modules"]
}
